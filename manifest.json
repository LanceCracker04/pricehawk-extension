{
  "manifest_version": 3,
  "name": "PriceHawk – Amazon Price Tracker & Deal Finder",
  "short_name": "PriceHawk",
  "version": "0.1.0",
  "description": "Tracks prices on product pages, alerts you when they drop, and applies your affiliate link automatically.",
  "icons": {
    "16": "public/icons/icon16.png",
    "48": "public/icons/icon48.png",
    "128": "public/icons/icon128.png"
  },
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16": "public/icons/icon16.png",
      "48": "public/icons/icon48.png",
      "128": "public/icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "src/background.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["*://*.amazon.com/*"],
      "js": ["src/content.ts"],
      "run_at": "document_idle"
    }
  ],
  "permissions": ["storage", "alarms", "notifications"],
  "host_permissions": ["*://*.amazon.com/*"]
}
